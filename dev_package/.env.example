# Environment Variables — GenRoute Cambodia Address Engine
# Copy this file to .env in the root directory and fill in your keys

# ─────────────────────────────────────────────────────────────
# REQUIRED FOR FULL GEOCODING CAPABILITY
# ─────────────────────────────────────────────────────────────

# Google Maps Geocoding API Key
# Get from: https://console.cloud.google.com/
# Enable: Geocoding API + Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─────────────────────────────────────────────────────────────
# OPTIONAL
# ─────────────────────────────────────────────────────────────

# Gemini API Key (for AI-powered geocoding fallback)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Server port (default: 3000)
PORT=3000
